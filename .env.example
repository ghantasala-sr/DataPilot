# ─── GCP Project ─────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id
REGION=us-central1
BQ_LOCATION=US

# ─── Cloud Storage ───────────────────────────────────────────
RAW_BUCKET=datapilot-raw-${PROJECT_ID}
SNAPSHOT_BUCKET=datapilot-snapshots-${PROJECT_ID}

# ─── Artifact Registry ──────────────────────────────────────
ARTIFACT_REPO=datapilot-containers

# ─── BigQuery Datasets ──────────────────────────────────────
RAW_DATASET=datapilot_raw
STAGING_DATASET=datapilot_staging
ANALYTICS_DATASET=datapilot_analytics
SEMANTIC_DATASET=datapilot_semantic
OBSERVABILITY_DATASET=datapilot_observability

# ─── Vertex AI / Gemini ─────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
MAX_BYTES_PROCESSED=10737418240

# ─── Backend ─────────────────────────────────────────────────
ENVIRONMENT=local
# Set false in production. Local phase-6 UI uses test-mock-token.
ALLOW_MOCK_AUTH=true
BACKEND_PORT=8080
LOG_LEVEL=INFO

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
